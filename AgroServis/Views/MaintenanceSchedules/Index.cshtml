@model List<AgroServis.Services.DTO.MaintenanceScheduleDto>

@{
    ViewData["Title"] = "Maintenance Schedules";
}

<h2>Maintenance Schedules</h2>
@if (ViewBag.EquipmentId != null)
{
    <div class="alert alert-info">
        Showing schedules for selected equipment.
    </div>
}
<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        Create Schedule
    </a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Equipment</th>
            <th>Task</th>
            <th>Interval (days)</th>
            <th>Last Performed</th>
            <th>Next Due</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EquipmentName</td>

                <td>@item.Title</td>

                <td>@item.IntervalDays</td>

                <td>
                    @(item.LastPerformedAt?.ToString("yyyy-MM-dd") ?? "-")
                </td>

                <td>@item.NextDueDate.ToString("yyyy-MM-dd")</td>

                <td>
                    @if (item.IsOverdue)
                    {
                        <span class="badge bg-danger">Overdue</span>
                    }
                    else if (item.DaysUntilDue <= 7)
                    {
                        <span class="badge bg-warning text-dark">Due Soon</span>
                    }
                    else
                    {
                        <span class="badge bg-success">On Time</span>
                    }
                </td>

                <td class="text-end">

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <form asp-action="Delete"
                          asp-route-id="@item.Id"
                          method="post"
                          class="d-inline"
                          onsubmit="return confirm('Delete this schedule?');">

                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>