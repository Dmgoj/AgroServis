@model AgroServis.Services.DTO.MaintenanceReportOptionsDto

@{
    ViewData["Title"] = "Maintenance Report Builder";
}

<h2>Maintenance Report</h2>

<form asp-action="PrintReport" method="post">

    <div class="card mb-4">
        <div class="card-header">
            <strong>Filters</strong>
        </div>

        <div class="card-body row g-3">

            <div class="col-md-4">
                <label class="form-label">Equipment</label>
                <select asp-for="EquipmentId"
                        asp-items="Model.AvailableEquipment"
                        class="form-select">
                    <option value="">All equipment</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Date From</label>
                <input asp-for="DateFrom" type="date" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Date To</label>
                <input asp-for="DateTo" type="date" class="form-control" />
            </div>

        </div>
    </div>


    <div class="card mb-4">
        <div class="card-header">
            <strong>Select fields to include in report</strong>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-4">

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeEquipmentName" />
                        <label class="form-check-label" asp-for="IncludeEquipmentName">
                            Equipment Name
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeSerialNumber" />
                        <label class="form-check-label" asp-for="IncludeSerialNumber">
                            Serial Number
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeMaintenanceDate" />
                        <label class="form-check-label" asp-for="IncludeMaintenanceDate">
                            Maintenance Date
                        </label>
                    </div>

                </div>


                <div class="col-md-4">

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeType" />
                        <label class="form-check-label" asp-for="IncludeType">
                            Maintenance Type
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeStatus" />
                        <label class="form-check-label" asp-for="IncludeStatus">
                            Status
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeCost" />
                        <label class="form-check-label" asp-for="IncludeCost">
                            Cost
                        </label>
                    </div>

                </div>


                <div class="col-md-4">

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeDescription" />
                        <label class="form-check-label" asp-for="IncludeDescription">
                            Description
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludeNotes" />
                        <label class="form-check-label" asp-for="IncludeNotes">
                            Notes
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="IncludePerformedBy" />
                        <label class="form-check-label" asp-for="IncludePerformedBy">
                            Performed By
                        </label>
                    </div>

                </div>

            </div>

        </div>
    </div>


    <div class="d-flex gap-2">

        <button type="submit" class="btn btn-primary">
            Generate PDF
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </div>

</form>